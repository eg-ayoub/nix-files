{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#27282290",
                "editor.background": "#27282290",
                "editor.foreground": "#f8f8f2",
                "text": "#f8f8f2",
                "text.muted": "#f8f8f270",
                "text.ignored": "#f8f8f240",
                "text.placeholder": "#f8f8f250",
                "ignored": "#f8f8f230",
                "element.hover": "#f8f8f230",
                "ghost_element.hover": "#f9267230",
                "ghost_element.selected": "#f9267230",
                "ghost_element.active": "#f9267260",
                "border": "#272822",
                "editor.highlighted_line.background": "#f9267210",
                "editor.active_line.background": "#f9267210",
                "panel.background": "#27282290",
                "title_bar.background": "#27282290",
                "title_bar.inactive_background": "#27282290",
                "status_bar.background": "#27282290",
                "drop_target.background": "#27282290",
                "elevated_surface.background": "#272822",
                "toolbar.background": "#27282290",
                "tab_bar.background": "#27282290",
                "tab.inactive_background": "#27282290",
                "tab.active_background": "#f9267230",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#272822",
                "scrollbar.thumb.background": "#f92672",
                "editor.gutter.background": "#27282290",
                "terminal.background": "#27282210",
                "terminal.foreground": "#f8f8f2",
                "terminal.dim_foreground": "#f8f8f2",
                "terminal.bright_foreground": "#f8f8f2",
                "terminal.ansi.black": "#272822",
                "terminal.ansi.red": "#f92672",
                "terminal.ansi.green": "#a6e22e",
                "terminal.ansi.yellow": "#f4bf75",
                "terminal.ansi.blue": "#66d9ef",
                "terminal.ansi.magenta": "#ae81ff",
                "terminal.ansi.cyan": "#a1efe4",
                "terminal.ansi.white": "#f8f8f2",
                "terminal.ansi.bright_black": "#75715e",
                "terminal.ansi.bright_red": "#f92672",
                "terminal.ansi.bright_green": "#a6e22e",
                "terminal.ansi.bright_yellow": "#f4bf75",
                "terminal.ansi.bright_blue": "#66d9ef",
                "terminal.ansi.bright_magenta": "#ae81ff",
                "terminal.ansi.bright_cyan": "#a1efe4",
                "terminal.ansi.bright_white": "#f9f8f5",
                "modified": "#f92672",
                "syntax": {
                    "attribute": {
                        "color": "#f92672"
                    },
                    "boolean": {
                      "color": "#a6e22e"
                    },
                    "comment": {
                      "color": "#75715e"
                    },
                    "comment.doc": {
                      "color": "#75715e"
                    },
                    "constant": {
                      "color": "#a6e22e"
                    },
                    "function": {
                      "color": "#a1efe4"
                    },
                    "keyword": {
                      "color": "#66d9ef"
                    },
                    "number": {
                      "color": "#ae81ff"
                    },
                    "operator": {
                      "color": "#66d9ef"
                    },
                    "string": {
                      "color": "#f92672"
                    },
                    "variable": {
                      "color": "#a6e22e"
                    }
                },
                "players": [
                  {
                    "cursor": "#f92672",
                    "background": "#272822",
                    "selection": "#f9267230"
                  }
                ]
            }
        }
    ]
}
