# create some params
typeset -U path cdpath fpath manpath

# andote
ANTIDOTE_HOME="$HOME/.antidote"
# first time setup if does not exist
if [[ ! -d "$ANTIDOTE_HOME" ]]; then
  git clone --depth=1 https://github.com/mattmc3/antidote.git $ANTIDOTE_HOME
fi
source "$ANTIDOTE_HOME"/antidote.zsh
antidote load "$HOME"/.zsh_plugins.txt

# ?
autoload -U compinit && compinit

# history
HISTSIZE="10000"
SAVEHIST="10000"

HISTFILE="$HOME/.zsh_history"
mkdir -p "$(dirname "$HISTFILE")"

setopt HIST_FCNTL_LOCK
unsetopt APPEND_HISTORY
setopt HIST_IGNORE_DUPS
unsetopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
unsetopt HIST_EXPIRE_DUPS_FIRST
setopt SHARE_HISTORY
unsetopt EXTENDED_HISTORY

# some bindings
bindkey '^[OA' history-beginning-search-backward
bindkey '^[OB' history-beginning-search-forward

bindkey '^ ' autosuggest-accept

# ssh with gpg
export GPG_TTY="$(tty)"
export SSH_AUTH_SOCK=$(gpgconf --list-dirs agent-ssh-socket)
gpgconf --launch gpg-agent
gpg-connect-agent updatestartuptty /bye > /dev/null

# kitty shell integration
if test -n "$KITTY_INSTALLATION_DIR"; then
  export KITTY_SHELL_INTEGRATION="no-rc"
  autoload -Uz -- "$KITTY_INSTALLATION_DIR"/shell-integration/zsh/kitty-integration
  kitty-integration
  unfunction kitty-integration
fi

# aliases
alias -- gfpush='ggpush --force'
alias -- glc='git log --format='\''%H'\'' -n 1'
alias -- lssh='TERM=xterm ssh -F ssh_config'
alias -- lscp='scp -F ssh_config'
alias -- lv='nvim .'
alias -- v='nvim'
alias -- fv='fzf --bind '\''enter:become(nvim {})'\'''
alias -- hgrep="history 0 | rg"

wtree () {
  if [[ $PWD/ != $HOME/repos/* ]]; then; echo "not inside repos" && return 1; fi
  if [[ ! -d $PWD/.git ]]; then; echo "not a git repo" && return 1; fi
  if [[ $PWD/ == $HOME/repos/worktrees/* ]]; then; echo "already in git worktree" && return 1; fi
  if [[ ! -d $HOME/repos/worktrees/"${PWD#"$HOME"/repos/}" ]]; then; mkdir -p "$HOME/repos/worktrees/${PWD#"$HOME"/repos/}"; fi
  git worktree add -B "$1" "$HOME/repos/worktrees/${PWD#"$HOME"/repos/}/$1" "$(git_current_branch)"
}

# per-machine settings
[[ -f "$HOME/.zsh_extra" ]] && source "$HOME/.zsh_extra"

# starship
eval "$(starship init zsh)"

# add local bin to path
export PATH="$HOME/.local/bin:$PATH"
